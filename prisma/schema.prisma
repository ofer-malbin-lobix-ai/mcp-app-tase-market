generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TaseSecuritiesEndOfDayTradingData {
  id                    String    @id @default(cuid())
  tradeDate             DateTime  @db.Date
  firstTradingDate      DateTime? @db.Date
  isin                  String
  change                Float?
  securityId            Int
  turnover              BigInt?
  closingPrice          Float?
  basePrice             Float?
  openingPrice          Float?
  high                  Float?
  low                   Float?
  changeValue           Float?
  transactionsNumber    Int?
  volume                BigInt?
  marketCap             BigInt?
  minContPhaseAmount    Int?
  listedCapital         BigInt?
  adjustedClosingPrice  Float?
  exCode                String?
  adjustmentCoefficient Float?
  symbol                String
  marketType            String?
  taseSymbol            TaseSymbol? @relation(fields: [symbol], references: [symbol])
  // --- indicators ---
  rsi14                 Float?
  macd                  Float?
  macdSignal            Float?
  macdHist              Float?
  cci20                 Float?
  mfi14                 Float?
  turnover10            Float?
  sma20                 Float?
  sma50                 Float?
  sma200                Float?
  ez                    Float?
  stddev20              Float?
  upperBollingerBand20  Float?
  lowerBollingerBand20  Float?
  bandWidth20           Float?

  @@unique([symbol, tradeDate], name: "unique_symbol_tradeDate")
  @@index([symbol, tradeDate], name: "index_symbol_tradeDate")
}

model TaseSymbol {
  symbol             String   @id
  securityId         Int      @unique
  isin               String
  securityName       String?
  companySuperSector String?
  companySector      String?
  companySubSector   String?
  companyName        String?
  updatedAt          DateTime @updatedAt
  tradingData        TaseSecuritiesEndOfDayTradingData[]
}

model AppUser {
  id            String              @id // Auth0 sub claim
  email         String?             @unique
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  positions     UserPosition[]
  watchlist     UserWatchlistItem[]
  subscription  UserSubscription?
}

model UserPosition {
  id            String   @id @default(cuid())
  userId        String
  symbol        String
  startDate     String
  amount        Float
  avgEntryPrice Float?
  alloc         Float?
  side          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
}

model UserWatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  startDate String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
}

model UserSubscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  plan                 String?
  paypalSubscriptionId String?
  subscriptionStatus   String?
  expiresAt            String?
  manualSubscription   Boolean  @default(false)
  freeTrial            Boolean  @default(false)
  freeTrialUsed        Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
}
