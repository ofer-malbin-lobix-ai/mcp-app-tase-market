# Server port
PORT=3001

# App URL
APP_URL=https://your-app-url.example.com

# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth0 (OAuth authorization server for MCP)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# TASE Data Hub API
TASE_DATA_HUB_API_KEY=your-tase-data-hub-api-key

# Cron: enable TASE Data Hub EOD pipeline (Mon-Thu 18:00-22:00, Fri 14:00-18:00, every 15 min Israel time)
ENABLE_FETCH_TASE_DATA_CRON=true or false

# Environment name (shown in Telegram notifications)
ENVIRONMENT_NAME=development

# Telegram notifications (optional, for EOD pipeline cron)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
