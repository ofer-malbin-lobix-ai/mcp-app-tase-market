# PayPal Configuration
# Get these from https://developer.paypal.com/dashboard
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_PLAN_MONTHLY=your-paypal-monthly-plan-id
PAYPAL_PLAN_YEARLY=your-paypal-yearly-plan-id

# App URL (for PayPal return URLs)
APP_URL=https://your-app-url.example.com

# Neon PostgreSQL
# Use a SEPARATE Neon project for local dev to avoid modifying production data.
# Production DATABASE_URL is set in Railway env vars.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth0 (OAuth authorization server for MCP)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# TASE Data Hub API
TASE_DATA_HUB_API_KEY=your-tase-data-hub-api-key
SUBSCRIBE_TOKEN_SECRET=your-subscribe-token-secret

# Cron: enable TASE Data Hub EOD pipeline (Mon-Fri 20:30 Israel time)
ENABLE_FETCH_TASE_DATA_CRON=false
